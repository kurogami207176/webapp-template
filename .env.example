# ============================================================
# Application
# ============================================================
ENVIRONMENT=development
LOG_LEVEL=info

# ============================================================
# Database
# ============================================================
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webapp_dev

# ============================================================
# Auth
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000

# ============================================================
# AWS (required for deployment)
# ============================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
