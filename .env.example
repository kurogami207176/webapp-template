# ============================================================
# Application
# ============================================================
ENVIRONMENT=development
LOG_LEVEL=info

# ============================================================
# Auth
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# DynamoDB
# ============================================================
AWS_REGION=us-east-1
USERS_TABLE_NAME=webapp-users
SESSIONS_TABLE_NAME=webapp-sessions
# Uncomment to point at a local DynamoDB (e.g. docker run amazon/dynamodb-local)
# DYNAMODB_ENDPOINT_URL=http://localhost:8001

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000

# ============================================================
# AWS (required for deployment)
# ============================================================
AWS_ACCOUNT_ID=123456789012
